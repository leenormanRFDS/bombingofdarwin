# Copy to .env for local dev, and set the same in Vercel → Settings → Environment Variables.
# NEVER commit real values. .env is gitignored.

# Rezdy Supplier API key (SECRET — server-side only, never sent to the browser)
REZDY_API_KEY=

# The Rezdy product/booking code for the experience
REZDY_PRODUCT_CODE=

# Leave both blank to run the booking skin on realistic mock data.
