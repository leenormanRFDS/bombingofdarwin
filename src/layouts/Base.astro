---
import '../styles/tokens.css';
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Analytics from '../components/Analytics.astro';
import { SITE } from '../consts';

interface Props {
  title?: string;
  description?: string;
  bare?: boolean; // landing page: hero only, no footer / booking bars
  depth?: 'surface' | 'mid' | 'descent' | 'seabed'; // the water column
}
const { title, description = SITE.description, bare = false, depth = 'mid' } = Astro.props;
const fullTitle = title ? `${title} · ${SITE.name}` : `${SITE.name} · ${SITE.tagline}`;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={Astro.url.href} />

    <!-- Social -->
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="theme-color" content="#0c0a08" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://use.typekit.net" crossorigin />
    <link rel="stylesheet" href="https://use.typekit.net/hoe3ija.css" />
    <link
      href="https://fonts.googleapis.com/css2?family=Spectral:ital,wght@0,400;0,500;1,400&family=Work+Sans:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <Analytics />
  </head>
  <body class="grain" data-depth={depth}>
    <a class="skip" href="#main">Skip to content</a>
    <Nav />
    <main id="main">
      <slot />
    </main>
    {!bare && <Footer />}

    {!bare && (
      <!-- Mobile sticky booking bar -->
      <div class="bookbar">
        <span class="bookbar__from">FROM <b>$18</b> · CHILD</span>
        <a class="btn" href={SITE.bookPath}>Book Tickets</a>
      </div>
    )}

    <!-- Desktop sticky Book Now — surfaces after the hero -->
    {!bare && Astro.url.pathname !== SITE.bookPath && Astro.url.pathname !== `${SITE.bookPath}/` && (
      <a class="btn-book bookfab" href={SITE.bookPath} data-bookfab aria-hidden="true" tabindex="-1">Book Now</a>
    )}

    <!-- Global weighted smooth scroll, synced to GSAP ScrollTrigger -->
    <script>
      import Lenis from 'lenis';
      import gsap from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';
      gsap.registerPlugin(ScrollTrigger);
      if (!matchMedia('(prefers-reduced-motion: reduce)').matches) {
        const lenis = new Lenis({ lerp: 0.085, wheelMultiplier: 1 });
        lenis.on('scroll', ScrollTrigger.update);
        gsap.ticker.add((t) => lenis.raf(t * 1000));
        gsap.ticker.lagSmoothing(0);
        (window as any).__lenis = lenis;
      }

      // Sitewide scroll reveal: section content resolves from soft focus.
      // (Pages with bespoke reveals — e.g. [data-reveal] on The Story — are untouched.)
      if (!matchMedia('(prefers-reduced-motion: reduce)').matches && 'IntersectionObserver' in window) {
        const containers = document.querySelectorAll<HTMLElement>('main .section > .container, main .section--tight > .container');
        const io = new IntersectionObserver(
          (entries) => entries.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('is-in'); io.unobserve(e.target); } }),
          { rootMargin: '0px 0px -18% 0px', threshold: 0.05 }
        );
        containers.forEach((c) => {
          Array.from(c.children).forEach((child, i) => {
            const el = child as HTMLElement;
            if (el.hasAttribute('data-reveal') || el.tagName === 'SCRIPT' || el.tagName === 'STYLE') return;
            el.setAttribute('data-areveal', '');
            el.style.setProperty('--ad', String(Math.min(i, 6)));
            io.observe(el);
          });
        });
      }

      // Marine snow: a sparse field of motes. The page rises past them as you
      // scroll — the descent made visible. Aperiodic by construction: no tile,
      // no repeat, never the same twice.
      if (!matchMedia('(prefers-reduced-motion: reduce)').matches) {
        const canvas = document.createElement('canvas');
        canvas.className = 'snow';
        canvas.setAttribute('aria-hidden', 'true');
        document.body.appendChild(canvas);
        const ctx = canvas.getContext('2d')!;
        const depthName = document.body.dataset.depth || 'mid';
        const SPEED = depthName === 'seabed' ? 0.35 : depthName === 'descent' ? 0.55 : 0.8;
        let W = 0, H = 0;
        const size = () => { W = canvas.width = innerWidth; H = canvas.height = innerHeight; };
        size();
        window.addEventListener('resize', size);
        const motes = Array.from({ length: 42 }, () => ({
          x: Math.random(), y: Math.random(),
          r: 0.4 + Math.random() * 0.9,
          a: 0.03 + Math.random() * 0.07,
          vy: 4 + Math.random() * 9,
          vx: (Math.random() - 0.5) * 2,
          ph: Math.random() * Math.PI * 2,
        }));
        let last = performance.now(), sy = window.scrollY;
        const frame = (t: number) => {
          const dt = Math.min(0.05, (t - last) / 1000); last = t;
          const ds = window.scrollY - sy; sy = window.scrollY;
          ctx.clearRect(0, 0, W, H);
          ctx.fillStyle = '#ECE7DB';
          for (const m of motes) {
            m.y += (m.vy * SPEED * dt) / H;      // slow sink
            m.y -= (ds * 0.12) / H;              // the page rises past them
            m.x += (m.vx * dt + Math.sin(t / 4000 + m.ph) * 0.05 * dt) / 10;
            if (m.y > 1.02) { m.y = -0.02; m.x = Math.random(); }
            if (m.y < -0.04) { m.y = 1.01; m.x = Math.random(); }
            if (m.x > 1.01) m.x = 0; else if (m.x < -0.01) m.x = 1;
            ctx.globalAlpha = m.a;
            ctx.beginPath();
            ctx.arc(m.x * W, m.y * H, m.r, 0, 7);
            ctx.fill();
          }
          requestAnimationFrame(frame);
        };
        requestAnimationFrame(frame);
      }

      // Sticky Book Now: surfaces once the visitor is past the first screen
      const fab = document.querySelector<HTMLElement>('[data-bookfab]');
      if (fab) {
        const toggle = () => {
          const show = window.scrollY > innerHeight * 0.85;
          fab.classList.toggle('is-live', show);
          fab.setAttribute('aria-hidden', String(!show));
          fab.tabIndex = show ? 0 : -1;
        };
        toggle();
        window.addEventListener('scroll', toggle, { passive: true });
      }
    </script>
  </body>
</html>
