---
import Base from '../layouts/Base.astro';
import Interstitial from '../components/Interstitial.astro';
import PlotBoard from '../components/PlotBoard.astro';

const timeline = [
  { t: '08:00', h: 'The strike launches', d: 'One hundred and eighty‑eight aircraft — Zeros, dive bombers and level bombers — lift from the Japanese carrier fleet in the Timor Sea.' },
  { t: '09:35', h: 'The warning that wasn’t heard', d: 'The mission on Bathurst Island radios a large formation approaching. It is discounted as the returning American P‑40s.' },
  { t: '09:58', h: 'The first bombs fall', d: 'With no siren and no warning, the first raid breaks over the harbour and town. It will last about forty minutes.' },
  { t: '10:00', h: 'The Post Office', d: 'A direct hit kills nine — the postmaster, his family and his staff — sheltering in a trench.' },
  { t: '10:45', h: 'USS Peary', d: 'The American destroyer, one of the largest ships in the harbour, is struck by five bombs.' },
  { t: '12:00', h: 'The second raid', d: 'Fifty‑four land‑based bombers return at high altitude to strike the RAAF base at Parap.' },
  { t: '13:00', h: 'Peary is lost', d: 'She sinks stern‑first. Ninety‑one of her crew go down with her — the heaviest single loss of American life in Australian waters.' },
  { t: 'Dusk', h: 'The reckoning begins', d: 'At least 235 are dead. Eight ships lie sunk, more than thirty aircraft destroyed. More bombs fell on Darwin than on Pearl Harbour.' },
];
---
<Base title="The Story — 19 February 1942" description="A chronological account of the first attacks on the Australian mainland — the raid on Darwin that no siren warned of." depth="descent">
  <!-- Intro — a full screen of silence -->
  <section class="s-intro">
    <div class="container s-intro__inner">
      <p class="eyebrow s-el" style="--i:0">19 February 1942</p>
      <h1 class="s-monument s-el" style="--i:1">The Bombing<br />of Darwin</h1>
      <div class="s-rule s-el" style="--i:2"></div>
      <p class="s-lede s-el" style="--i:3">
        A chronological account of the first attacks on the Australian mainland. Behind the timeline are
        people — those who decided, those who fought, and those whose lives were changed forever.
      </p>
    </div>
    <div class="s-scroll s-el" style="--i:4"><span class="s-scroll__label">Scroll to begin</span><span class="s-scroll__track"><span></span></span></div>
  </section>

  <!-- Archival interstitial — the raid breaks -->
  <Interstitial
    src="/images/story/raid-wide.webp"
    alt="Japanese aircraft over Darwin Harbour as the first bombs fall, 19 February 1942"
    record="09:58 ACST · 19 February 1942"
    line="With no siren and no warning, the first bombs fell on the harbour."
    register="archival"
    align="left"
  />

  <!-- Mobile: the plot lives BEHIND the timeline — surfacing between events,
       re-framing toward each contact as its moment passes -->
  <div class="s-plotbg" data-plotbg aria-hidden="true">
    <div class="s-plotbg__pan" data-plotpan>
      <PlotBoard mode="live" />
    </div>
  </div>

  <!-- The morning's clock — ticks forward as you scroll -->
  <div class="s-clock" data-clock aria-hidden="true">
    <span class="s-clock__t record" data-clock-t>08:00</span>
    <span class="s-clock__z record">ACST</span>
  </div>
  <!-- 09:58 — one frame of white, then the light never recovers -->
  <div class="s-flash" data-flash aria-hidden="true"></div>
  <div class="s-smoke" data-smoke aria-hidden="true"></div>

  <!-- The timeline, with the operations plot alongside -->
  <section class="s-tl-section">
    <div class="container s-tl-grid">
      <div class="tl" data-tl>
        <div class="tl__line" aria-hidden="true"></div>
        <div class="tl__progress" data-progress aria-hidden="true"></div>

        {timeline.map((e) => (
          <article class="tl__event">
            <span class="tl__node" data-reveal aria-hidden="true"></span>
            <div class="tl__row">
              <div class="tl__time" data-reveal>{e.t}</div>
              <div class="tl__body">
                <h2 class="tl__title" data-reveal>{e.h}</h2>
                <p class="tl__desc" data-reveal>{e.d}</p>
              </div>
            </div>
          </article>
        ))}
      </div>

      <aside class="s-plotwrap" aria-label="The morning plotted on Darwin Harbour">
        <div class="s-plotstick">
          <PlotBoard mode="live" />
        </div>
      </aside>
    </div>
  </section>

  <!-- Mobile: the completed plot, the morning as one artifact -->
  <section class="s-plot-mobile">
    <div class="container">
      <p class="eyebrow" data-reveal>The morning, plotted</p>
      <div data-reveal><PlotBoard mode="complete" /></div>
    </div>
  </section>

  <!-- Archival footage -->
  <section class="s-film">
    <div class="container">
      <p class="eyebrow" data-reveal>Archival footage</p>
      <h2 class="s-film__h" data-reveal>See it for yourself.</h2>
      <div class="film" data-reveal>
        <button class="film__player" data-yt="inqvsMqvrrE" aria-label="Play archival footage of the Bombing of Darwin">
          <img class="film__poster" src="https://i.ytimg.com/vi/inqvsMqvrrE/maxresdefault.jpg" alt="" loading="lazy" decoding="async" width="1280" height="720" />
          <span class="film__scrim"></span>
          <span class="film__play"><svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M8 5.2v13.6L19 12z" /></svg></span>
          <span class="tk tl"></span><span class="tk tr"></span><span class="tk bl"></span><span class="tk br"></span>
        </button>
      </div>
    </div>
  </section>

  <!-- Present-day resolve — the then/now payoff after the descent -->
  <Interstitial
    src="/images/story/harbour-today.webp"
    alt="Stokes Hill Wharf and Darwin Harbour today, calm under a clear sky"
    record="The same harbour · today"
    line="Today the same water lies calm. The wharf remembers."
    register="present"
    align="left"
  />

  <!-- The Reckoning -->
  <section class="s-reckon">
    <div class="container">
      <p class="eyebrow" data-reveal>The Reckoning</p>
      <h2 class="s-reckon__h" data-reveal>The bombing changed<br />Australia forever.</h2>
      <p class="s-reckon__p" data-reveal>
        Today Darwin stands as a place of remembrance and resilience. Across the city, memorials and wartime
        sites honour those who served, those who were lost, and the community that rebuilt. The raids did not
        end that day — they were the first of more than sixty on northern Australia.
      </p>
      <p class="s-reckon__lest" data-reveal>Lest we forget.</p>
      <a class="s-reckon__mem" href="/memorial" data-reveal>In Memoriam — those who were lost →</a>
    </div>
  </section>

  <!-- The threshold — the story stops here; the experience continues at the wharf -->
  <section class="s-threshold">
    <div class="container">
      <p class="s-threshold__line" data-reveal>
        What those forty minutes felt like cannot be scrolled.<br />
        It is told standing where it happened.
      </p>
      <a class="btn-book" href="/tickets" data-reveal>Continue at the Wharf</a>
      <p class="record s-threshold__sub" data-reveal>Every ticket includes both experiences · Stokes Hill Wharf, Darwin</p>
    </div>
  </section>
</Base>

<style>
  /* ---------- intro ---------- */
  .s-intro { min-height: 100svh; display: flex; flex-direction: column; justify-content: center; position: relative; padding-block: calc(var(--nav-h) + 40px) 40px; }
  .s-intro__inner { max-width: 1000px; }
  .s-monument { font-family: var(--font-display-xl); font-weight: 400; text-transform: uppercase; line-height: 0.92; letter-spacing: 0.01em; color: var(--bone); font-size: clamp(3.2rem, 12vw, 8.5rem); margin: 0 0 clamp(28px, 4vw, 48px); text-shadow: 0 -1px 0 rgba(0,0,0,0.6), 0 1px 0 rgba(236,231,219,0.04), 0 0 12px rgba(236,231,219,0.05); }
  .s-rule { width: 64px; height: 1px; background: var(--line-strong); margin-bottom: clamp(28px, 4vw, 48px); }
  .s-lede { font-family: var(--font-serif); font-size: clamp(1.25rem, 2.4vw, 1.9rem); line-height: 1.5; color: var(--bone-dim); max-width: 42ch; margin: 0; }

  .s-scroll { position: absolute; bottom: clamp(28px, 5vh, 56px); left: var(--gutter); display: flex; align-items: flex-end; gap: 14px; }
  .s-scroll__label { font-family: var(--font-mono); font-size: 0.66rem; letter-spacing: 0.3em; text-transform: uppercase; color: var(--bone-mute); writing-mode: vertical-rl; transform: rotate(180deg); }
  .s-scroll__track { width: 1px; height: 60px; background: var(--line); position: relative; overflow: hidden; }
  .s-scroll__track span { position: absolute; inset: 0; background: var(--gold); animation: sScroll 2.2s linear infinite; }
  @keyframes sScroll { 0% { transform: translateY(-100%); } 100% { transform: translateY(100%); } }

  /* intro load reveal */
  .s-el { opacity: 0; transform: translateY(40px); filter: blur(10px); animation: sRise 1.6s var(--ease-solemn) both; animation-delay: calc(var(--i) * 0.14s + 0.1s); }
  @keyframes sRise { to { opacity: 1; transform: none; filter: blur(0); } }

  /* ---------- timeline ---------- */
  .s-tl-section { padding-bottom: clamp(60px, 10vh, 140px); }
  .tl { position: relative; --tl-pad: clamp(80px, 14vh, 190px); }
  .tl__line, .tl__progress { position: absolute; left: 0; top: 0; bottom: 0; width: 1px; }
  .tl__line { background: var(--line); }
  .tl__progress { background: var(--gold); transform: scaleY(0); transform-origin: top; box-shadow: 0 0 12px rgba(198, 161, 91, 0.5); }

  .tl__event { position: relative; padding-left: clamp(28px, 5vw, 60px); padding-block: var(--tl-pad); }
  .tl__node { position: absolute; left: -5px; top: calc(var(--tl-pad) + clamp(14px, 2.3vw, 26px)); width: 11px; height: 11px; border-radius: 50%; background: var(--gold); box-shadow: 0 0 0 5px var(--ink), 0 0 16px rgba(198, 161, 91, 0.7); }
  .tl__row { display: grid; gap: clamp(10px, 3vw, 64px); }
  @media (min-width: 820px) { .tl__row { grid-template-columns: 200px 1fr; align-items: start; } }

  .tl__time { font-family: var(--font-display); font-weight: 400; text-transform: uppercase; letter-spacing: 0.04em; color: var(--gold); font-size: clamp(2rem, 5vw, 3.4rem); line-height: 1; text-shadow: 0 0 24px rgba(198, 161, 91, 0.3); }
  .tl__title { font-family: var(--font-display); font-weight: 400; text-transform: uppercase; letter-spacing: 0.01em; color: var(--bone); font-size: clamp(1.8rem, 4.4vw, 3.2rem); line-height: 1.02; margin: 0 0 clamp(16px, 2vw, 28px); }
  .tl__desc { font-family: var(--font-serif); font-size: clamp(1.15rem, 2vw, 1.55rem); line-height: 1.6; color: var(--bone-dim); max-width: 34ch; margin: 0; }

  /* ---------- reckoning ---------- */
  .s-reckon { min-height: 90svh; display: flex; flex-direction: column; justify-content: center; border-top: 1px solid var(--line); padding-block: clamp(80px, 14vh, 180px); }
  .s-reckon__h { font-family: var(--font-display-xl); font-weight: 400; text-transform: uppercase; line-height: 0.94; color: var(--bone); font-size: clamp(2.4rem, 8vw, 5.5rem); margin: 20px 0 clamp(28px, 4vw, 44px); }
  .s-reckon__p { font-family: var(--font-serif); font-size: clamp(1.2rem, 2.2vw, 1.7rem); line-height: 1.55; color: var(--bone-dim); max-width: 44ch; margin: 0 0 clamp(40px, 6vw, 72px); }
  .s-reckon__lest { font-family: var(--font-mono); font-size: 0.9rem; letter-spacing: 0.34em; text-transform: uppercase; color: var(--bone-mute); margin: 0; }
  .s-reckon__mem { display: inline-block; margin-top: clamp(28px, 4vw, 44px); font-family: var(--font-mono); font-size: 0.74rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--gold-bright); border-bottom: 1px solid var(--line-strong); padding-bottom: 4px; transition: border-color 0.25s var(--ease); }
  .s-reckon__mem:hover { border-color: var(--gold); }

  /* ---------- archival footage ---------- */
  .s-film { padding-block: clamp(60px, 10vh, 130px); border-top: 1px solid var(--line); }
  .s-film__h { font-family: var(--font-display); font-weight: 400; text-transform: uppercase; font-size: clamp(1.8rem, 4vw, 3rem); color: var(--bone); margin: 14px 0 clamp(28px, 4vw, 44px); letter-spacing: 0.01em; }
  .film { position: relative; }
  .film__player { position: relative; display: block; width: 100%; aspect-ratio: 16 / 9; overflow: hidden; border: 1px solid var(--line-strong); background: var(--ink); cursor: pointer; padding: 0; }
  .film__poster { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; filter: grayscale(0.55) contrast(1.05); transition: filter 0.5s var(--ease), transform 0.6s var(--ease); }
  .film__player:hover .film__poster { filter: grayscale(0.15) contrast(1.05); transform: scale(1.02); }
  .film__scrim { position: absolute; inset: 0; background: radial-gradient(circle at center, rgba(12,12,11,0.15) 0%, rgba(12,12,11,0.6) 100%); }
  .film__play { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); width: clamp(66px, 8vw, 92px); height: clamp(66px, 8vw, 92px); border-radius: 50%; display: grid; place-items: center; background: rgba(12,12,11,0.55); border: 1px solid rgba(236,231,219,0.6); backdrop-filter: blur(6px); color: var(--bone); transition: background 0.3s var(--ease), border-color 0.3s var(--ease), transform 0.3s var(--ease); }
  .film__play svg { width: 40%; height: 40%; margin-left: 8%; }
  .film__player:hover .film__play { background: var(--gold); border-color: var(--gold); color: var(--ink); transform: translate(-50%, -50%) scale(1.06); }
  .film .tk { position: absolute; width: 15px; height: 15px; border: 1px solid var(--bone); opacity: 0.5; z-index: 3; pointer-events: none; }
  .film .tk.tl { top: 10px; left: 10px; border-right: 0; border-bottom: 0; }
  .film .tk.tr { top: 10px; right: 10px; border-left: 0; border-bottom: 0; }
  .film .tk.bl { bottom: 10px; left: 10px; border-right: 0; border-top: 0; }
  .film .tk.br { bottom: 10px; right: 10px; border-left: 0; border-top: 0; }
  .film iframe { position: absolute; inset: 0; width: 100%; height: 100%; border: 0; }

  /* ---------- the plot board layout ---------- */
  .s-plotwrap { display: none; }
  /* the completed-plot section serves reduced-motion visitors only —
     everyone else gets the living board behind the timeline */
  .s-plot-mobile { display: none; padding-block: clamp(48px, 8vw, 90px); border-top: 1px solid var(--line); }
  .s-plot-mobile .eyebrow { margin-bottom: 24px; }
  .s-plot-mobile .plot { max-width: 560px; }
  @media (max-width: 1099px) and (prefers-reduced-motion: reduce) {
    .s-plot-mobile { display: block; }
  }
  @media (min-width: 1100px) {
    /* NB: no align-items:start — the plot column must stretch to the full row
       height or the sticky board has no track to travel (it would scroll away) */
    .s-tl-grid { display: grid; grid-template-columns: minmax(0, 1fr) 400px; gap: clamp(48px, 5vw, 88px); }
    .s-plotwrap { display: block; min-width: 0; align-self: stretch; }
    .s-plotstick { position: sticky; top: calc(var(--nav-h) + 36px); }
    /* contacts are instruments: click to travel to that moment */
    .s-plotstick :global([data-ev]) { cursor: pointer; outline: none; }
    .s-plotstick :global([data-ev]:hover .pm__l),
    .s-plotstick :global([data-ev]:focus-visible .pm__l) { fill: rgba(236, 231, 219, 0.85); }
    .s-plotstick :global([data-ev]:hover .pm__dot),
    .s-plotstick :global([data-ev]:focus-visible .pm__dot) { fill: var(--gold-bright); }
  }

  /* ---------- the plot behind the story (mobile) ---------- */
  .s-plotbg {
    display: none; position: fixed; inset: 0; z-index: 0; pointer-events: none;
    align-items: center; justify-content: center;
    opacity: 0; transition: opacity 0.5s linear;
  }
  @media (max-width: 1099px) and (prefers-reduced-motion: no-preference) {
    .s-plotbg { display: flex; }
    /* the timeline floats above the board; each event becomes a record card
       so the type stays sovereign over the drawing */
    .s-tl-section { position: relative; z-index: 1; }
    .tl__row {
      background: linear-gradient(175deg, rgba(19, 18, 16, 0.88), rgba(12, 12, 11, 0.78));
      border: 1px solid var(--line); padding: 18px 18px 20px;
    }
    /* interludes: space between events where the board comes forward */
    .tl__event { padding-bottom: 44vh; }
    .tl__event:last-child { padding-bottom: 12vh; }
  }
  .s-plotbg__pan {
    width: min(96vw, 74vh); will-change: transform;
    transition: transform 1.6s var(--ease-solemn);
  }
  .s-plotbg :global(.plot__head), .s-plotbg :global(.plot__cap) { display: none; }
  .s-plotbg :global(.plot__board) { border: 0; background: none; }

  /* ---------- the clock ---------- */
  .s-clock {
    position: fixed; right: var(--gutter); top: 50%; transform: translateY(-50%);
    z-index: 40; display: flex; flex-direction: column; align-items: flex-end; gap: 4px;
    opacity: 0; transition: opacity 0.8s var(--ease); pointer-events: none;
  }
  .s-clock.is-on { opacity: 1; }
  .s-clock__t { font-size: 1.05rem; letter-spacing: 0.2em; color: var(--gold-bright); }
  .s-clock__z { font-size: 0.56rem; color: var(--bone-mute); }
  @media (max-width: 900px) { .s-clock { display: none; } }
  /* on wide screens the plot board carries the clock instead */
  @media (min-width: 1100px) { .s-clock { display: none; } }

  /* ---------- 09:58 ---------- */
  /* not a strobe — a bloom of light, like the sky brightening through eyelids */
  .s-flash {
    position: fixed; inset: 0; z-index: 90; opacity: 0; pointer-events: none;
    background: radial-gradient(120% 90% at 50% 30%, var(--bone) 0%, rgba(236, 231, 219, 0.6) 45%, transparent 100%);
  }
  .s-flash.is-flash { animation: flashOnce 1.8s cubic-bezier(0.2, 0, 0.4, 1) forwards; }
  @keyframes flashOnce {
    0% { opacity: 0; }
    18% { opacity: 0.34; }
    100% { opacity: 0; }
  }
  .s-smoke {
    position: fixed; inset: 0; z-index: 55; pointer-events: none; opacity: 0;
    background: linear-gradient(180deg, rgba(10, 8, 6, 0.12) 0%, rgba(10, 8, 6, 0.34) 60%, rgba(8, 6, 5, 0.5) 100%);
    transition: opacity 3s var(--ease);
  }
  .s-smoke.is-on { opacity: 1; }

  /* ---------- the threshold ---------- */
  .s-threshold { text-align: center; padding-block: clamp(80px, 16vh, 180px); border-top: 1px solid var(--line); position: relative; z-index: 1; }
  .s-threshold__line { font-family: var(--font-serif); font-style: italic; font-size: clamp(1.4rem, 3.2vw, 2.3rem); line-height: 1.5; color: var(--bone); margin: 0 0 clamp(36px, 5vw, 52px); }
  .s-threshold__sub { color: var(--bone-mute); margin: 18px 0 0; }

  /* ---------- scroll-reveal (blur-in) ---------- */
  [data-reveal] { opacity: 0; transform: translateY(30px); filter: blur(5px); transition: opacity 1.3s var(--ease-solemn), transform 1.3s var(--ease-solemn), filter 1.3s var(--ease-solemn); }
  [data-reveal][data-shown] { opacity: 1; transform: none; filter: blur(0); }
  .tl__title[data-reveal] { transition-delay: 0.1s; }
  .tl__desc[data-reveal] { transition-delay: 0.2s; }
  .tl__node[data-reveal] { transform: scale(0); filter: none; transition: opacity 1s var(--ease-solemn), transform 1s var(--ease-solemn); }
  .tl__node[data-reveal][data-shown] { transform: scale(1); }

  @media (prefers-reduced-motion: reduce) {
    .s-el { animation: none; opacity: 1; transform: none; filter: none; }
    .s-scroll__track span { animation: none; }
    [data-reveal] { opacity: 1; transform: none; filter: none; }
    .tl__node[data-reveal] { transform: scale(1); }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;

  // Blur-in reveals, triggered as each element reaches the centre
  const items = document.querySelectorAll<HTMLElement>('[data-reveal]');
  if (reduce || !('IntersectionObserver' in window)) {
    items.forEach((i) => i.setAttribute('data-shown', ''));
  } else {
    const io = new IntersectionObserver(
      (entries) => entries.forEach((e) => { if (e.isIntersecting) { e.target.setAttribute('data-shown', ''); io.unobserve(e.target); } }),
      { rootMargin: '0px 0px -30% 0px', threshold: 0.1 }
    );
    items.forEach((i) => io.observe(i));
  }

  // Archival footage: swap the poster for the YouTube player only on click (fast first paint)
  const player = document.querySelector<HTMLButtonElement>('[data-yt]');
  if (player) {
    player.addEventListener('click', () => {
      const id = player.dataset.yt;
      const iframe = document.createElement('iframe');
      iframe.src = `https://www.youtube-nocookie.com/embed/${id}?autoplay=1&rel=0&modestbranding=1`;
      iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture';
      iframe.allowFullscreen = true;
      iframe.title = 'Archival footage — the Bombing of Darwin';
      player.replaceWith(iframe);
    });
  }

  // The morning's clock + the 09:58 moment.
  // The scroll advances the clock through the timeline's hours; crossing 09:58
  // fires one frame of white (once), and the light never quite recovers.
  const clock = document.querySelector<HTMLElement>('[data-clock]');
  const clockT = document.querySelector<HTMLElement>('[data-clock-t]');
  const flash = document.querySelector<HTMLElement>('[data-flash]');
  const smoke = document.querySelector<HTMLElement>('[data-smoke]');
  const events = Array.from(document.querySelectorAll<HTMLElement>('.tl__event'));
  if (clock && clockT && events.length) {
    const times = events.map((e) => e.querySelector('.tl__time')?.textContent?.trim() || '');
    const bombIdx = times.indexOf('09:58');
    // the live plot boards (desktop companion + mobile backdrop): contacts
    // kindle as their events pass; every board is driven identically
    const livePlots = Array.from(document.querySelectorAll<HTMLElement>('[data-plot="live"]')).map((pl) => ({
      pl,
      marks: Array.from(pl.querySelectorAll<HTMLElement>('[data-ev]')),
      bearing: pl.querySelector<SVGPathElement>('[data-bearing]'),
      clockEl: pl.querySelector<HTMLElement>('.plot__d'),
      lost: pl.querySelector<HTMLElement>('[data-lost]'),
    }));
    if (reduce) livePlots.forEach(({ pl }) => pl.classList.add('plot--complete'));

    // the mobile backdrop: focus between slides, re-frame toward each contact
    const bg = document.querySelector<HTMLElement>('[data-plotbg]');
    const pan = document.querySelector<HTMLElement>('[data-plotpan]');
    // svg-space centres of each event's contact (ev6 = Peary again; ev7 = overview)
    const CONTACTS: Array<[number, number] | null> =
      [[22, 36], [132, 180], [352, 468], [396, 408], [240, 500], [452, 278], [240, 500], null];
    let lastPan = -2;

    // each contact on the desktop board navigates to its moment in the story
    const deskBoard = document.querySelector<HTMLElement>('.s-plotstick [data-plot="live"]');
    deskBoard?.querySelectorAll<SVGGElement>('[data-ev]').forEach((m) => {
      const i = Number(m.dataset.ev);
      const target = events[Math.min(i, events.length - 1)];
      if (!target) return;
      m.setAttribute('role', 'link');
      m.setAttribute('tabindex', '0');
      m.setAttribute('aria-label', `Go to ${times[i] || ''} in the timeline`);
      const go = () => {
        const y = target.offsetTop - window.innerHeight * 0.32;
        const lenis = (window as any).__lenis;
        if (lenis) lenis.scrollTo(y, { duration: 1.4 });
        else window.scrollTo({ top: y, behavior: 'smooth' });
      };
      m.addEventListener('click', go);
      m.addEventListener('keydown', (e: KeyboardEvent) => {
        if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); go(); }
      });
    });

    let flashed = false;
    let raf = 0;
    const update = () => {
      raf = 0;
      const mid = window.scrollY + window.innerHeight * 0.55;
      const first = events[0], last = events[events.length - 1];
      const inTl = mid > first.offsetTop && window.scrollY < last.offsetTop + last.offsetHeight + 200;
      clock.classList.toggle('is-on', inTl);
      let cur = -1;
      for (let i = 0; i < events.length; i++) if (events[i].offsetTop < mid) cur = i;
      if (cur >= 0 && clockT.textContent !== times[cur]) {
        clockT.textContent = times[cur];
        if (!reduce) clockT.animate([{ opacity: 0.2 }, { opacity: 1 }], { duration: 500, easing: 'ease-out' });
        const t = times[cur] === 'Dusk' ? 'Dusk' : `${times[cur]} ACST`;
        livePlots.forEach(({ clockEl }) => { if (clockEl) clockEl.textContent = t; });
      }
      const past958 = bombIdx >= 0 && cur >= bombIdx;
      if (past958 && !flashed) {
        flashed = true;
        if (!reduce && flash) flash.classList.add('is-flash');
      }
      smoke?.classList.toggle('is-on', past958);

      // drive every board: kindle contacts, draw the bearing in reaches, mark the loss
      if (!reduce) {
        livePlots.forEach(({ pl, marks, bearing, lost }) => {
          marks.forEach((m) => m.classList.toggle('is-lit', cur >= Number(m.dataset.ev)));
          // The head of the bearing = the formation's position at each recorded
          // moment: launched (08:00), over Bathurst at exactly t=1/3 (09:35, the
          // transmission), over the harbour (09:58). Timing honoured in geometry.
          if (bearing) bearing.style.strokeDashoffset = String(cur >= 2 ? 0 : cur >= 1 ? 0.667 : cur >= 0 ? 0.88 : 1);
          lost?.classList.toggle('is-x', cur >= 6);
          pl.classList.toggle('is-dusk', cur >= 7);
        });
      }

      // the backdrop board: recede under text, surface between slides,
      // and re-frame toward the current contact
      if (bg && pan && !reduce && window.innerWidth < 1100) {
        let nd = 1;
        for (const e of events) {
          const r = e.getBoundingClientRect();
          const d = Math.abs(r.top + r.height / 2 - window.innerHeight / 2) / (window.innerHeight * 0.5);
          if (d < nd) nd = d;
        }
        // 0 when an event card is centred → board recedes; 1 in the interludes
        const focus = Math.min(1, Math.max(0, (nd - 0.22) / 0.55));
        bg.style.opacity = inTl ? String(0.24 + focus * 0.52) : '0';

        if (cur !== lastPan) {
          lastPan = cur;
          const c = cur >= 0 ? CONTACTS[Math.min(cur, CONTACTS.length - 1)] : null;
          if (!c) {
            pan.style.transform = 'none';
          } else {
            const s = pan.clientWidth / 600; // svg units → px
            const Z = 1.5;
            const px = (c[0] - 300) * s, py = (c[1] - 380) * s;
            pan.style.transform = `translate(${(-px * Z).toFixed(1)}px, ${(-py * Z).toFixed(1)}px) scale(${Z})`;
          }
        }
      } else if (bg) {
        bg.style.opacity = '0';
      }
    };
    const onScroll = () => { if (!raf) raf = requestAnimationFrame(update); };
    window.addEventListener('scroll', onScroll, { passive: true });
    update();
  }

  // The line draws itself as you descend the timeline
  const tl = document.querySelector('.tl');
  const progress = document.querySelector('.tl__progress');
  if (tl && progress && !reduce) {
    gsap.to(progress, {
      scaleY: 1,
      ease: 'none',
      scrollTrigger: { trigger: tl, start: 'top center', end: 'bottom center', scrub: 0.6 },
    });
  } else if (progress && reduce) {
    (progress as HTMLElement).style.transform = 'scaleY(1)';
  }
</script>
