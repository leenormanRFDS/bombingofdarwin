---
import Base from '../layouts/Base.astro';

const timeline = [
  { t: '08:00', h: 'The strike launches', d: 'One hundred and eighty‑eight aircraft — Zeros, dive bombers and level bombers — lift from the Japanese carrier fleet in the Timor Sea.' },
  { t: '09:35', h: 'The warning that wasn’t heard', d: 'The mission on Bathurst Island radios a large formation approaching. It is discounted as the returning American P‑40s.' },
  { t: '09:58', h: 'The first bombs fall', d: 'With no siren and no warning, the first raid breaks over the harbour and town. It will last about forty minutes.' },
  { t: '10:00', h: 'The Post Office', d: 'A direct hit kills nine — the postmaster, his family and his staff — sheltering in a trench.' },
  { t: '10:45', h: 'USS Peary', d: 'The American destroyer, one of the largest ships in the harbour, is struck by five bombs.' },
  { t: '12:00', h: 'The second raid', d: 'Fifty‑four land‑based bombers return at high altitude to strike the RAAF base at Parap.' },
  { t: '13:00', h: 'Peary is lost', d: 'She sinks stern‑first. Ninety‑one of her crew go down with her — the heaviest single loss of American life in Australian waters.' },
  { t: 'Dusk', h: 'The reckoning begins', d: 'At least 235 are dead. Eight ships lie sunk, more than thirty aircraft destroyed. More bombs fell on Darwin than on Pearl Harbour.' },
];
---
<Base title="The Story — 19 February 1942" description="A chronological account of the first attacks on the Australian mainland — the raid on Darwin that no siren warned of.">
  <!-- Intro — a full screen of silence -->
  <section class="s-intro">
    <div class="container s-intro__inner">
      <p class="eyebrow s-el" style="--i:0">Chapter II · 19 February 1942</p>
      <h1 class="s-monument s-el" style="--i:1">The Bombing<br />of Darwin</h1>
      <div class="s-rule s-el" style="--i:2"></div>
      <p class="s-lede s-el" style="--i:3">
        A chronological account of the first attacks on the Australian mainland. Behind the timeline are
        people — those who decided, those who fought, and those whose lives were changed forever.
      </p>
    </div>
    <div class="s-scroll s-el" style="--i:4"><span class="s-scroll__label">Scroll to begin</span><span class="s-scroll__track"><span></span></span></div>
  </section>

  <!-- The timeline -->
  <section class="s-tl-section">
    <div class="container">
      <div class="tl" data-tl>
        <div class="tl__line" aria-hidden="true"></div>
        <div class="tl__progress" data-progress aria-hidden="true"></div>

        {timeline.map((e) => (
          <article class="tl__event">
            <span class="tl__node" data-reveal aria-hidden="true"></span>
            <div class="tl__row">
              <div class="tl__time" data-reveal>{e.t}</div>
              <div class="tl__body">
                <h2 class="tl__title" data-reveal>{e.h}</h2>
                <p class="tl__desc" data-reveal>{e.d}</p>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Archival footage -->
  <section class="s-film">
    <div class="container">
      <p class="eyebrow" data-reveal>Archival footage</p>
      <h2 class="s-film__h" data-reveal>See it for yourself.</h2>
      <div class="film" data-reveal>
        <button class="film__player" data-yt="inqvsMqvrrE" aria-label="Play archival footage of the Bombing of Darwin">
          <img class="film__poster" src="https://i.ytimg.com/vi/inqvsMqvrrE/maxresdefault.jpg" alt="" loading="lazy" decoding="async" width="1280" height="720" />
          <span class="film__scrim"></span>
          <span class="film__play"><svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M8 5.2v13.6L19 12z" /></svg></span>
          <span class="tk tl"></span><span class="tk tr"></span><span class="tk bl"></span><span class="tk br"></span>
        </button>
      </div>
    </div>
  </section>

  <!-- The Reckoning -->
  <section class="s-reckon">
    <div class="container">
      <p class="eyebrow" data-reveal>The Reckoning</p>
      <h2 class="s-reckon__h" data-reveal>The bombing changed<br />Australia forever.</h2>
      <p class="s-reckon__p" data-reveal>
        Today Darwin stands as a place of remembrance and resilience. Across the city, memorials and wartime
        sites honour those who served, those who were lost, and the community that rebuilt. The raids did not
        end that day — they were the first of more than sixty on northern Australia.
      </p>
      <p class="s-reckon__lest" data-reveal>Lest we forget.</p>
      <a class="s-reckon__mem" href="/memorial" data-reveal>In Memoriam — those who were lost →</a>
    </div>
  </section>
</Base>

<style>
  /* ---------- intro ---------- */
  .s-intro { min-height: 100svh; display: flex; flex-direction: column; justify-content: center; position: relative; padding-block: calc(var(--nav-h) + 40px) 40px; }
  .s-intro__inner { max-width: 1000px; }
  .s-monument { font-family: var(--font-display-xl); font-weight: 400; text-transform: uppercase; line-height: 0.92; letter-spacing: 0.01em; color: var(--bone); font-size: clamp(3.2rem, 12vw, 8.5rem); margin: 0 0 clamp(28px, 4vw, 48px); text-shadow: 0 0 50px rgba(236, 231, 219, 0.12); }
  .s-rule { width: 64px; height: 1px; background: var(--line-strong); margin-bottom: clamp(28px, 4vw, 48px); }
  .s-lede { font-family: var(--font-serif); font-size: clamp(1.25rem, 2.4vw, 1.9rem); line-height: 1.5; color: var(--bone-dim); max-width: 42ch; margin: 0; }

  .s-scroll { position: absolute; bottom: clamp(28px, 5vh, 56px); left: var(--gutter); display: flex; align-items: flex-end; gap: 14px; }
  .s-scroll__label { font-family: var(--font-mono); font-size: 0.66rem; letter-spacing: 0.3em; text-transform: uppercase; color: var(--bone-mute); writing-mode: vertical-rl; transform: rotate(180deg); }
  .s-scroll__track { width: 1px; height: 60px; background: var(--line); position: relative; overflow: hidden; }
  .s-scroll__track span { position: absolute; inset: 0; background: var(--gold); animation: sScroll 2.2s linear infinite; }
  @keyframes sScroll { 0% { transform: translateY(-100%); } 100% { transform: translateY(100%); } }

  /* intro load reveal */
  .s-el { opacity: 0; transform: translateY(40px); filter: blur(10px); animation: sRise 1.6s var(--ease-solemn) both; animation-delay: calc(var(--i) * 0.14s + 0.1s); }
  @keyframes sRise { to { opacity: 1; transform: none; filter: blur(0); } }

  /* ---------- timeline ---------- */
  .s-tl-section { padding-bottom: clamp(60px, 10vh, 140px); }
  .tl { position: relative; --tl-pad: clamp(80px, 14vh, 190px); }
  .tl__line, .tl__progress { position: absolute; left: 0; top: 0; bottom: 0; width: 1px; }
  .tl__line { background: var(--line); }
  .tl__progress { background: var(--gold); transform: scaleY(0); transform-origin: top; box-shadow: 0 0 12px rgba(198, 161, 91, 0.5); }

  .tl__event { position: relative; padding-left: clamp(28px, 5vw, 60px); padding-block: var(--tl-pad); }
  .tl__node { position: absolute; left: -5px; top: calc(var(--tl-pad) + clamp(14px, 2.3vw, 26px)); width: 11px; height: 11px; border-radius: 50%; background: var(--gold); box-shadow: 0 0 0 5px var(--ink), 0 0 16px rgba(198, 161, 91, 0.7); }
  .tl__row { display: grid; gap: clamp(10px, 3vw, 64px); }
  @media (min-width: 820px) { .tl__row { grid-template-columns: 200px 1fr; align-items: start; } }

  .tl__time { font-family: var(--font-display); font-weight: 400; text-transform: uppercase; letter-spacing: 0.04em; color: var(--gold); font-size: clamp(2rem, 5vw, 3.4rem); line-height: 1; text-shadow: 0 0 24px rgba(198, 161, 91, 0.3); }
  .tl__title { font-family: var(--font-display); font-weight: 400; text-transform: uppercase; letter-spacing: 0.01em; color: var(--bone); font-size: clamp(1.8rem, 4.4vw, 3.2rem); line-height: 1.02; margin: 0 0 clamp(16px, 2vw, 28px); }
  .tl__desc { font-family: var(--font-serif); font-size: clamp(1.15rem, 2vw, 1.55rem); line-height: 1.6; color: var(--bone-dim); max-width: 34ch; margin: 0; }

  /* ---------- reckoning ---------- */
  .s-reckon { min-height: 90svh; display: flex; flex-direction: column; justify-content: center; border-top: 1px solid var(--line); padding-block: clamp(80px, 14vh, 180px); }
  .s-reckon__h { font-family: var(--font-display-xl); font-weight: 400; text-transform: uppercase; line-height: 0.94; color: var(--bone); font-size: clamp(2.4rem, 8vw, 5.5rem); margin: 20px 0 clamp(28px, 4vw, 44px); }
  .s-reckon__p { font-family: var(--font-serif); font-size: clamp(1.2rem, 2.2vw, 1.7rem); line-height: 1.55; color: var(--bone-dim); max-width: 44ch; margin: 0 0 clamp(40px, 6vw, 72px); }
  .s-reckon__lest { font-family: var(--font-mono); font-size: 0.9rem; letter-spacing: 0.34em; text-transform: uppercase; color: var(--bone-mute); margin: 0; }
  .s-reckon__mem { display: inline-block; margin-top: clamp(28px, 4vw, 44px); font-family: var(--font-mono); font-size: 0.74rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--gold-bright); border-bottom: 1px solid var(--line-strong); padding-bottom: 4px; transition: border-color 0.25s var(--ease); }
  .s-reckon__mem:hover { border-color: var(--gold); }

  /* ---------- archival footage ---------- */
  .s-film { padding-block: clamp(60px, 10vh, 130px); border-top: 1px solid var(--line); }
  .s-film__h { font-family: var(--font-display); font-weight: 400; text-transform: uppercase; font-size: clamp(1.8rem, 4vw, 3rem); color: var(--bone); margin: 14px 0 clamp(28px, 4vw, 44px); letter-spacing: 0.01em; }
  .film { position: relative; }
  .film__player { position: relative; display: block; width: 100%; aspect-ratio: 16 / 9; overflow: hidden; border: 1px solid var(--line-strong); background: var(--ink); cursor: pointer; padding: 0; }
  .film__poster { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; filter: grayscale(0.55) contrast(1.05); transition: filter 0.5s var(--ease), transform 0.6s var(--ease); }
  .film__player:hover .film__poster { filter: grayscale(0.15) contrast(1.05); transform: scale(1.02); }
  .film__scrim { position: absolute; inset: 0; background: radial-gradient(circle at center, rgba(12,12,11,0.15) 0%, rgba(12,12,11,0.6) 100%); }
  .film__play { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); width: clamp(66px, 8vw, 92px); height: clamp(66px, 8vw, 92px); border-radius: 50%; display: grid; place-items: center; background: rgba(12,12,11,0.55); border: 1px solid rgba(236,231,219,0.6); backdrop-filter: blur(6px); color: var(--bone); transition: background 0.3s var(--ease), border-color 0.3s var(--ease), transform 0.3s var(--ease); }
  .film__play svg { width: 40%; height: 40%; margin-left: 8%; }
  .film__player:hover .film__play { background: var(--gold); border-color: var(--gold); color: var(--ink); transform: translate(-50%, -50%) scale(1.06); }
  .film .tk { position: absolute; width: 15px; height: 15px; border: 1px solid var(--bone); opacity: 0.5; z-index: 3; pointer-events: none; }
  .film .tk.tl { top: 10px; left: 10px; border-right: 0; border-bottom: 0; }
  .film .tk.tr { top: 10px; right: 10px; border-left: 0; border-bottom: 0; }
  .film .tk.bl { bottom: 10px; left: 10px; border-right: 0; border-top: 0; }
  .film .tk.br { bottom: 10px; right: 10px; border-left: 0; border-top: 0; }
  .film iframe { position: absolute; inset: 0; width: 100%; height: 100%; border: 0; }

  /* ---------- scroll-reveal (blur-in) ---------- */
  [data-reveal] { opacity: 0; transform: translateY(30px); filter: blur(5px); transition: opacity 1.3s var(--ease-solemn), transform 1.3s var(--ease-solemn), filter 1.3s var(--ease-solemn); }
  [data-reveal][data-shown] { opacity: 1; transform: none; filter: blur(0); }
  .tl__title[data-reveal] { transition-delay: 0.1s; }
  .tl__desc[data-reveal] { transition-delay: 0.2s; }
  .tl__node[data-reveal] { transform: scale(0); filter: none; transition: opacity 1s var(--ease-solemn), transform 1s var(--ease-solemn); }
  .tl__node[data-reveal][data-shown] { transform: scale(1); }

  @media (prefers-reduced-motion: reduce) {
    .s-el { animation: none; opacity: 1; transform: none; filter: none; }
    .s-scroll__track span { animation: none; }
    [data-reveal] { opacity: 1; transform: none; filter: none; }
    .tl__node[data-reveal] { transform: scale(1); }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;

  // Blur-in reveals, triggered as each element reaches the centre
  const items = document.querySelectorAll<HTMLElement>('[data-reveal]');
  if (reduce || !('IntersectionObserver' in window)) {
    items.forEach((i) => i.setAttribute('data-shown', ''));
  } else {
    const io = new IntersectionObserver(
      (entries) => entries.forEach((e) => { if (e.isIntersecting) { e.target.setAttribute('data-shown', ''); io.unobserve(e.target); } }),
      { rootMargin: '0px 0px -30% 0px', threshold: 0.1 }
    );
    items.forEach((i) => io.observe(i));
  }

  // Archival footage: swap the poster for the YouTube player only on click (fast first paint)
  const player = document.querySelector<HTMLButtonElement>('[data-yt]');
  if (player) {
    player.addEventListener('click', () => {
      const id = player.dataset.yt;
      const iframe = document.createElement('iframe');
      iframe.src = `https://www.youtube-nocookie.com/embed/${id}?autoplay=1&rel=0&modestbranding=1`;
      iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture';
      iframe.allowFullscreen = true;
      iframe.title = 'Archival footage — the Bombing of Darwin';
      player.replaceWith(iframe);
    });
  }

  // The line draws itself as you descend the timeline
  const tl = document.querySelector('.tl');
  const progress = document.querySelector('.tl__progress');
  if (tl && progress && !reduce) {
    gsap.to(progress, {
      scaleY: 1,
      ease: 'none',
      scrollTrigger: { trigger: tl, start: 'top center', end: 'bottom center', scrub: 0.6 },
    });
  } else if (progress && reduce) {
    (progress as HTMLElement).style.transform = 'scaleY(1)';
  }
</script>
