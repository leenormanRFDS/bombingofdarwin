---
import Base from '../layouts/Base.astro';

// The ten members of the Darwin Post Office staff, as inscribed on the
// memorial plaque. They were offered evacuation and chose to stay.
const postOffice = [
  { name: 'Hurtle C. Bald', role: 'Postmaster' },
  { name: 'Alice L. Bald', role: '' },
  { name: 'Iris E. Bald', role: '' },
  { name: 'Archibald T. R. Halls', role: '' },
  { name: 'Jean C. Mullen', role: '' },
  { name: 'Eileen C. Mullen', role: '' },
  { name: 'Jennie F. Stasinowsky', role: '' },
  { name: 'Arthur W. Wellington', role: '' },
  { name: 'Emily F. Young', role: '' },
  { name: 'Walter R. L. Rowling', role: '' },
];

// Honoured groups — documented losses of the day, held as numbers where names
// are not recorded on a single roll.
const fallen = [
  { n: '88', label: 'USS Peary', note: 'Of her crew of 144, only fifty-three survived. She sank stern-first in the harbour — the heaviest single loss of American life in Australian waters.' },
  { n: '45', label: 'MV Neptuna & the wharf', note: 'The merchant vessel Neptuna exploded at the main jetty; wharf labourers and ships’ crews were lost across the burning harbour.' },
  { n: '9', label: 'The ships of the harbour', note: 'Nine vessels were sunk that morning — among them the Neptuna, Zealandia, Mauna Loa, Meigs and the Peary.' },
  { n: '235+', label: 'The town and the Territory', note: 'Servicemen, wharf workers, postal staff, hospital patients and civilians. By nightfall at least 235 were dead — a toll historians still count today.' },
];
---
<Base title="In Memoriam" description="In memory of those who died in the Bombing of Darwin, 19 February 1942 — including the ten members of the Darwin Post Office staff who chose to stay. Lest we forget." depth="seabed">
  <!-- The seabed: the harbour floor beneath the page. The ships are still there.
       An evocation of the chart, not a navigation chart — positions indicative. -->
  <div class="seabed" aria-hidden="true">
    <svg viewBox="0 0 1400 1600" preserveAspectRatio="xMidYMid slice">
      <g fill="none" stroke="#ECE7DB" stroke-opacity="0.045" stroke-width="1.1">
        <path d="M-40 420 C 240 350, 520 400, 760 340 C 1020 275, 1260 330, 1460 280" />
        <path d="M-40 560 C 260 490, 540 545, 780 485 C 1040 420, 1270 480, 1460 430" />
        <path d="M-40 730 C 280 660, 560 720, 800 660 C 1050 600, 1280 660, 1460 615" />
        <path d="M-40 930 C 300 860, 580 925, 820 865 C 1070 805, 1290 865, 1460 825" />
        <path d="M-40 1160 C 320 1090, 600 1160, 840 1100 C 1080 1040, 1300 1100, 1460 1065" />
        <path d="M-40 1400 C 340 1330, 620 1405, 860 1345 C 1100 1285, 1310 1345, 1460 1315" />
      </g>
      <g class="seabed__wrecks" fill="none" stroke="#ECE7DB" stroke-opacity="0.1" stroke-width="1.2">
        <g transform="translate(320 1020)"><path d="M-7 -7 L7 7 M-7 7 L7 -7" /><text x="0" y="26">USS PEARY</text></g>
        <g transform="translate(640 880)"><path d="M-7 -7 L7 7 M-7 7 L7 -7" /><text x="0" y="26">NEPTUNA</text></g>
        <g transform="translate(920 1090)"><path d="M-7 -7 L7 7 M-7 7 L7 -7" /><text x="0" y="26">ZEALANDIA</text></g>
        <g transform="translate(480 1260)"><path d="M-7 -7 L7 7 M-7 7 L7 -7" /><text x="0" y="26">MAUNA LOA</text></g>
        <g transform="translate(1080 1330)"><path d="M-7 -7 L7 7 M-7 7 L7 -7" /><text x="0" y="26">MEIGS</text></g>
      </g>
    </svg>
  </div>

  <!-- Monument header -->
  <section class="mem-intro">
    <div class="container mem-intro__inner">
      <p class="eyebrow mem-el" style="--i:0">19 February 1942</p>
      <h1 class="mem-monument mem-el" style="--i:1">In Memoriam</h1>
      <div class="mem-rule mem-el" style="--i:2"></div>
      <p class="mem-lede mem-el" style="--i:3">
        By nightfall, at least two hundred and thirty-five people were dead. This page is for them —
        the named and the unnamed, the servicemen and the civilians, on the day the war reached home.
      </p>
    </div>
  </section>

  <!-- The Ode -->
  <section class="section mem-ode-sec">
    <div class="container">
      <blockquote class="mem-ode">
        <p>They shall grow not old, as we that are left grow old;</p>
        <p>Age shall not weary them, nor the years condemn.</p>
        <p>At the going down of the sun and in the morning</p>
        <p>We will remember them.</p>
      </blockquote>
    </div>
  </section>

  <!-- Honoured groups -->
  <section class="section mem-roll-sec">
    <div class="container">
      <p class="eyebrow eyebrow--gold">The fallen</p>
      <div class="mem-roll">
        {fallen.map((f) => (
          <article class="mem-row">
            <span class="mem-row__n">{f.n}</span>
            <div class="mem-row__body">
              <h2 class="mem-row__label">{f.label}</h2>
              <p class="mem-row__note">{f.note}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- The Post Office — named -->
  <section class="section mem-po-sec">
    <div class="container">
      <p class="eyebrow eyebrow--gold">The Darwin Post Office</p>
      <h2 class="mem-po__h">They were offered evacuation.<br />They chose to stay.</h2>
      <p class="mem-po__intro">
        A single bomb found the shelter in the postmaster's garden, where the telephonists and staff had
        gathered. Ten are remembered by name on the memorial that stands where they worked.
      </p>
      <ul class="mem-names">
        {postOffice.map((p) => (
          <li class="mem-name">
            <span class="mem-name__n">{p.name}</span>
            {p.role && <span class="mem-name__r">{p.role}</span>}
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Closing -->
  <section class="section mem-close">
    <div class="container">
      <p class="mem-note">
        The toll of 19 February 1942 has never been settled. Figures range from 235 to more than 290.
        Every count is an attempt to hold a number to a grief that resists it.
      </p>
      <p class="mem-lest">Lest we forget.</p>
    </div>
  </section>
</Base>

<style>
  /* ---- the seabed layer ---- */
  .seabed { position: fixed; inset: 0; z-index: 0; pointer-events: none; }
  .seabed svg { width: 100%; height: 100%; }
  .seabed__wrecks text {
    font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.22em;
    fill: rgba(236, 231, 219, 0.11); stroke: none; text-anchor: middle;
  }
  /* content floats above the floor */
  section { position: relative; z-index: 1; }

  /* ---- monument header ---- */
  .mem-intro { min-height: 84svh; display: flex; align-items: center; position: relative; padding-block: calc(var(--nav-h) + 40px) 40px; }
  .mem-intro__inner { max-width: 1000px; }
  .mem-monument { font-family: var(--font-display-xl); font-weight: 400; text-transform: uppercase; line-height: 0.9; letter-spacing: 0.01em; color: var(--bone); font-size: clamp(3rem, 11vw, 8rem); margin: 0 0 clamp(28px, 4vw, 48px); text-shadow: 0 -1px 0 rgba(0,0,0,0.6), 0 1px 0 rgba(236,231,219,0.04), 0 0 12px rgba(236,231,219,0.05); }
  .mem-rule { width: 64px; height: 1px; background: var(--line-strong); margin-bottom: clamp(28px, 4vw, 44px); }
  .mem-lede { font-family: var(--font-serif); font-size: clamp(1.2rem, 2.2vw, 1.7rem); line-height: 1.55; color: var(--bone-dim); max-width: 46ch; margin: 0; }

  /* ---- the Ode ---- */
  .mem-ode-sec { border-top: 1px solid var(--line); }
  .mem-ode { margin: 0; text-align: center; padding-block: clamp(20px, 5vw, 56px); }
  .mem-ode p { font-family: var(--font-serif); font-style: italic; font-size: clamp(1.3rem, 3vw, 2.1rem); line-height: 1.7; color: var(--bone); margin: 0; }
  .mem-ode p:nth-child(4) { color: var(--gold-bright); margin-top: 0.4em; }

  /* ---- honoured groups ---- */
  .mem-roll-sec { border-top: 1px solid var(--line); }
  .mem-roll { margin-top: 36px; }
  .mem-row { display: grid; grid-template-columns: minmax(90px, 130px) 1fr; gap: clamp(20px, 4vw, 52px); align-items: baseline; padding: clamp(24px, 4vw, 38px) 0; border-top: 1px solid var(--line); }
  .mem-row:first-child { border-top: 0; }
  .mem-row__n { font-family: var(--font-display-xl); font-weight: 400; font-size: clamp(2.6rem, 6vw, 4.4rem); color: var(--gold); line-height: 0.9; }
  .mem-row__label { font-family: var(--font-display); font-weight: 400; text-transform: uppercase; font-size: clamp(1.2rem, 2.4vw, 1.7rem); color: var(--bone); margin: 0 0 10px; letter-spacing: 0.01em; }
  .mem-row__note { font-family: var(--font-serif); font-size: 1.08rem; line-height: 1.65; color: var(--bone-dim); max-width: 52ch; margin: 0; }

  /* ---- Post Office named roll ---- */
  .mem-po-sec { border-top: 1px solid var(--line); }
  .mem-po__h { font-family: var(--font-display); font-weight: 400; text-transform: uppercase; font-size: clamp(1.6rem, 4vw, 2.8rem); line-height: 1.06; color: var(--bone); margin: 14px 0 22px; }
  .mem-po__intro { font-family: var(--font-serif); font-size: 1.15rem; line-height: 1.7; color: var(--bone-dim); max-width: 54ch; margin: 0 0 clamp(32px, 5vw, 52px); }
  .mem-names { list-style: none; padding: 0; margin: 0; display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 0; }
  .mem-name { display: flex; flex-direction: column; gap: 2px; padding: 20px 0; border-top: 1px solid var(--line); }
  .mem-name__n { font-family: var(--font-display-reg); font-weight: 500; font-size: 1.3rem; color: var(--bone); letter-spacing: 0.01em; }
  .mem-name__r { font-family: var(--font-mono); font-size: 0.66rem; letter-spacing: 0.16em; text-transform: uppercase; color: var(--gold); }

  /* ---- closing ---- */
  .mem-close { border-top: 1px solid var(--line); text-align: center; }
  .mem-note { font-family: var(--font-serif); font-size: 1.05rem; line-height: 1.7; color: var(--bone-mute); max-width: 56ch; margin: 0 auto clamp(40px, 6vw, 64px); font-style: italic; }
  .mem-lest { font-family: var(--font-mono); font-size: clamp(0.9rem, 2vw, 1.1rem); letter-spacing: 0.36em; text-transform: uppercase; color: var(--bone); margin: 0; }

  /* ---- intro load reveal ---- */
  .mem-el { opacity: 0; transform: translateY(40px); filter: blur(10px); animation: memRise 1.6s var(--ease-solemn) both; animation-delay: calc(var(--i) * 0.16s + 0.1s); }
  @keyframes memRise { to { opacity: 1; transform: none; filter: blur(0); } }
  @media (prefers-reduced-motion: reduce) { .mem-el { animation: none; opacity: 1; transform: none; filter: none; } }

  @media (max-width: 560px) {
    .mem-row { grid-template-columns: 1fr; gap: 10px; }
    .mem-names { grid-template-columns: 1fr; }
  }
</style>
