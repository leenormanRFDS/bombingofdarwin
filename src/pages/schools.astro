---
import Base from '../layouts/Base.astro';
import PageHeader from '../components/PageHeader.astro';
const groupEmail = 'bookingsdrw@flyingdoctor.net.au';
---
<Base title="Schools & Groups" description="Curriculum-linked immersive learning at the Bombing of Darwin Experience — history, STEM, aviation and innovation. Step inside 'PAPA', a decommissioned RFDS Pilatus PC-12.">
  <PageHeader
    record="Education & groups"
    title="Schools & Groups"
    lede="Curriculum-linked, immersive learning across Australian history, wartime studies, STEM, geography, aviation and innovation — through interactive storytelling and a discovery trail."
  />

  <section class="section">
    <div class="container">
      <div class="grid">
        <div>
          <p class="eyebrow">Step inside “PAPA”</p>
          <p class="prose--serif prose">
            Students climb aboard <em>PAPA</em> — a decommissioned Royal Flying Doctor Service Pilatus PC-12 —
            and discover how medicine reaches the most remote corners of the country. History and hope, in one visit.
          </p>
        </div>
        <div>
          <p class="eyebrow">At a glance</p>
          <dl class="deflist">
            <div><dt>Audience</dt><dd>Primary, secondary and tertiary students</dd></div>
            <div><dt>Group size</dt><dd>Up to 150 students per slot</dd></div>
            <div><dt>Duration</dt><dd>Approximately 2 hours</dd></div>
            <div><dt>Funding</dt><dd>Eligible schools may access the NT Learning Adventures “Save &amp; Learn” program</dd></div>
          </dl>
        </div>
      </div>

      <div class="cta">
        <p class="prose--serif prose measure" style="margin-bottom:22px;">
          Bespoke rates and resources are available for schools, tour operators and groups. Tell us your dates and numbers and we'll tailor the visit.
        </p>
        <a class="btn" href={`mailto:${groupEmail}`}>Enquire about group bookings</a>
        <p class="record" style="margin-top:14px;">{groupEmail}</p>
      </div>
    </div>
  </section>
</Base>

<style>
  .grid { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(32px, 6vw, 80px); margin-bottom: clamp(40px, 7vw, 72px); }
  .cta { padding-top: clamp(32px, 5vw, 56px); border-top: 1px solid var(--line); }
  @media (max-width: 760px) { .grid { grid-template-columns: 1fr; } }
</style>
