---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import { PRICES } from '../consts';
---
<Base>
  <Hero />

  <!-- Intro — the narrative chapters land below over the coming bricks -->
  <section class="section" id="experience">
    <div class="container">
      <p class="eyebrow">The Experience</p>
      <h2 class="title measure">Step into the day the war reached Australia.</h2>
      <p class="prose prose--serif measure">
        On the morning of 19 February 1942, more bombs fell on Darwin than on Pearl Harbour. At Stokes Hill
        Wharf you don't read about it — you're placed inside it: the Window to Darwin Harbour, the people who
        lived it, and a First Nations story carried through generations of Tiwi tradition. Every ticket
        includes both the Bombing of Darwin Experience and the Royal Flying Doctor Service Experience.
      </p>

      <div class="tiers">
        {PRICES.map((t) => (
          <div class="card tier">
            <span class="record tier__name">{t.tier}</span>
            <span class="tier__price">${t.price}</span>
            <span class="tier__note">{t.note ?? ' '}</span>
          </div>
        ))}
      </div>

      <a class="btn" href="/book">Book Tickets</a>
    </div>
  </section>
</Base>

<style>
  .title { max-width: 20ch; margin-bottom: 24px; }
  .section .prose { margin-bottom: 44px; }
  .tiers { display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px; margin-bottom: 40px; }
  .tier { display: flex; flex-direction: column; gap: 6px; padding: 20px; }
  .tier:hover { border-color: var(--gold); transform: translateY(-3px); }
  .tier__price { font-family: var(--font-display-xl); font-weight: 400; font-size: 2.4rem; color: var(--gold-bright); line-height: 1; }
  .tier__note { font-size: 0.74rem; color: var(--bone-mute); }
  @media (max-width: 680px) { .tiers { grid-template-columns: repeat(2, 1fr); } }
</style>
