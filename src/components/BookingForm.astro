---
import { PACKAGES } from '../consts';

const ICONS: Record<string, string> = {
  clock: '<circle cx="12" cy="12" r="9"/><path d="M12 7v5l3.2 2"/>',
  family: '<circle cx="9" cy="8" r="3"/><circle cx="17" cy="10" r="2.2"/><path d="M4 20c0-3 2.2-5 5-5s5 2 5 5M14.5 20c.2-2.4 1.6-4 3.5-4 1.4 0 2.6.8 3 2.4"/>',
  plane: '<path d="M10.5 13.5 3 11l1.5-2 6.5 1 5-6.5L18 3l-1.5 7.5 4 2.5-1.5 2-4.5-1.5-2 4.5-2-.5.5-4.5z"/>',
  headset: '<path d="M4 14v-2a8 8 0 0 1 16 0v2"/><rect x="3" y="14" width="4" height="6" rx="1.5"/><rect x="17" y="14" width="4" height="6" rx="1.5"/>',
  bus: '<rect x="4" y="4" width="16" height="13" rx="2"/><path d="M4 11h16M8 21v-2M16 21v-2"/><circle cx="8.5" cy="14.5" r="0.8"/><circle cx="15.5" cy="14.5" r="0.8"/>',
  ticket: '<path d="M4 8a2 2 0 0 0 2-2h12a2 2 0 0 0 2 2v3a2 2 0 0 0 0 4v3a2 2 0 0 0-2 2H6a2 2 0 0 0-2-2v-3a2 2 0 0 0 0-4z"/><path d="M12 7v2M12 11v2M12 15v2" stroke-dasharray="1 3"/>',
};
const icon = (n: string) =>
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">${ICONS[n] || ''}</svg>`;
---
<section class="bflow" aria-label="Book tickets" data-booking>
  <div class="bflow__steps">
    <!-- 01 · Choose experience -->
    <div class="step" id="step-exp">
      <div class="step__head"><span class="step__n">01</span><h2 class="step__t">Choose your experience</h2></div>
      <div class="packs">
        {PACKAGES.map((p) => (
          <button type="button" class={`pack ${p.glow ? 'pack--glow' : ''}`} data-pkg={p.slug} aria-pressed="false">
            <span class="pack__media">
              <img src={p.image} alt="" width="1000" height="620" loading="lazy" decoding="async" />
              {p.flag && <span class="pack__flag">{p.flag}</span>}
            </span>
            <span class="pack__body">
              <span class="pack__name">{p.name}</span>
              <span class="pack__pricewrap">
                <span class="pack__pricelabel">{p.lead.label}</span>
                <span class="pack__price"><em>$</em>{p.lead.price}</span>
                <span class="pack__per">per person</span>
              </span>
              <span class="pack__includes">
                <span class="pack__inclabel">Includes</span>
                {p.includes.map((x) => (
                  <span class="pack__inc"><b>✓</b> {x}</span>
                ))}
              </span>
              <span class="pack__meta">
                {p.meta.map((m) => (
                  <span class="pack__m"><span class="pack__mi" set:html={icon(m.icon)} /> {m.label}</span>
                ))}
              </span>
              <span class="pack__go">Select <i>→</i></span>
            </span>
          </button>
        ))}
      </div>
    </div>

    <!-- 02 · Who's coming -->
    <div class="step" id="step-who" data-step-who hidden>
      <div class="step__head"><span class="step__n">02</span><h2 class="step__t">Who's coming?</h2></div>
      <div class="tickets" data-tickets></div>
    </div>

    <!-- 03 · Date -->
    <div class="step" id="step-date" data-step-date hidden>
      <div class="step__head"><span class="step__n">03</span><h2 class="step__t">Select a date</h2></div>
      <div class="cal" data-dates><p class="hint" data-loading>Loading availability…</p></div>
      <p class="hint" data-mocknote hidden>Example times shown — live availability connects once Rezdy is linked.</p>
    </div>

    <!-- 04 · Time -->
    <div class="step" id="step-time" data-step-session hidden>
      <div class="step__head"><span class="step__n">04</span><h2 class="step__t">Select a time</h2></div>
      <div class="sessions" data-sessions></div>
    </div>
  </div>

  <!-- Your Visit — always visible, sticky -->
  <aside class="bsum" data-summary aria-label="Your visit summary">
    <p class="bsum__title">Your Visit</p>
    <div class="bsum__rows">
      <div class="bsum__row"><span class="bsum__k">Experience</span><span class="bsum__v" data-sum-pkg>—</span></div>
      <div class="bsum__row"><span class="bsum__k">Tickets</span><span class="bsum__v" data-sum-qty>—</span></div>
      <div class="bsum__row"><span class="bsum__k">Date</span><span class="bsum__v" data-sum-date>—</span></div>
      <div class="bsum__row"><span class="bsum__k">Time</span><span class="bsum__v" data-sum-time>—</span></div>
    </div>
    <div class="bsum__total"><span>Total</span><strong data-total>$0</strong></div>
    <button class="btn-book bsum__cta" data-book disabled>Continue</button>
    <p class="bsum__secure">Secure payment via Rezdy</p>
  </aside>

  <script type="application/json" data-packages set:html={JSON.stringify(PACKAGES)}></script>
</section>

<style>
  .bflow { display: grid; gap: clamp(28px, 4vw, 56px); align-items: start; }
  @media (min-width: 980px) { .bflow { grid-template-columns: minmax(0, 1fr) 330px; } }

  .step { padding: 36px 0 8px; }
  .step + .step { border-top: 1px solid var(--line); margin-top: 26px; }
  .step__head { display: flex; align-items: baseline; gap: 14px; margin-bottom: 24px; }
  .step__n { font-family: var(--font-mono); font-size: 0.82rem; letter-spacing: 0.1em; color: var(--gold); }
  .step__t { font-family: var(--font-display-reg); font-weight: 500; text-transform: none; font-size: clamp(1.3rem, 2.4vw, 1.65rem); margin: 0; letter-spacing: 0; }
  .hint { font-size: 0.9rem; color: var(--bone-mute); }

  /* ---------- 01 · vertical package cards with images ---------- */
  .packs { display: grid; gap: 22px; }
  .pack {
    position: relative; display: grid; text-align: left; padding: 0; overflow: hidden; cursor: pointer;
    background: linear-gradient(165deg, var(--char-2) 0%, var(--char) 70%);
    border: 1px solid var(--line); border-radius: 6px; color: var(--bone); font-family: inherit;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.4);
    transition: transform 0.35s var(--ease), border-color 0.35s var(--ease), box-shadow 0.35s var(--ease);
  }
  @media (min-width: 640px) { .pack { grid-template-columns: 42% 1fr; } }
  .pack:hover { transform: translateY(-4px); border-color: var(--line-strong); }
  .pack[aria-pressed='true'] { border-color: var(--gold); box-shadow: inset 0 0 0 1px var(--gold), 0 26px 60px rgba(0, 0, 0, 0.5), 0 0 44px rgba(198, 161, 91, 0.15); }
  .pack[aria-pressed='true'] .pack__go { color: var(--gold-bright); }
  .pack[aria-pressed='true'] .pack__go::before { content: '✓ Selected'; }
  .pack[aria-pressed='true'] .pack__go i, .pack[aria-pressed='true'] .pack__go b { display: none; }

  /* the glowing best-value panel */
  .pack--glow { border-color: rgba(198, 161, 91, 0.65); box-shadow: 0 0 0 1px rgba(198, 161, 91, 0.35), 0 0 42px rgba(198, 161, 91, 0.16), 0 20px 50px rgba(0, 0, 0, 0.45); }
  @media (prefers-reduced-motion: no-preference) {
    .pack--glow { animation: packGlow 4.5s ease-in-out infinite; }
    @keyframes packGlow {
      0%, 100% { box-shadow: 0 0 0 1px rgba(198, 161, 91, 0.35), 0 0 38px rgba(198, 161, 91, 0.14), 0 20px 50px rgba(0, 0, 0, 0.45); }
      50% { box-shadow: 0 0 0 1px rgba(228, 197, 131, 0.55), 0 0 64px rgba(198, 161, 91, 0.28), 0 20px 50px rgba(0, 0, 0, 0.45); }
    }
  }

  .pack__media { position: relative; display: block; min-height: 200px; }
  .pack__media img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  @media (max-width: 639px) { .pack__media { aspect-ratio: 16 / 9; min-height: 0; } .pack__media img { position: absolute; } }
  .pack__flag { position: absolute; top: 12px; left: 12px; font-family: var(--font-mono); font-size: 0.62rem; letter-spacing: 0.16em; text-transform: uppercase; color: var(--ink); background: var(--gold); padding: 5px 10px; border-radius: 2px; }

  .pack__body { display: flex; flex-direction: column; gap: 14px; padding: 26px 26px 22px; }
  .pack__name { font-family: var(--font-display); font-weight: 400; text-transform: uppercase; font-size: clamp(1.4rem, 2.6vw, 1.9rem); line-height: 1; letter-spacing: 0.01em; }
  .pack__pricewrap { display: flex; align-items: baseline; gap: 10px; flex-wrap: wrap; }
  .pack__pricelabel { font-family: var(--font-mono); font-size: 0.78rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--bone-dim); }
  .pack__price { font-family: var(--font-display-xl); font-weight: 400; font-size: 2.7rem; color: var(--gold-bright); line-height: 0.9; }
  .pack__price em { font-style: normal; font-size: 0.55em; vertical-align: 0.5em; color: var(--gold); }
  .pack__per { font-size: 0.85rem; color: var(--bone-mute); }

  .pack__includes { display: flex; flex-direction: column; gap: 7px; }
  .pack__inclabel { font-family: var(--font-mono); font-size: 0.66rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--bone-mute); margin-bottom: 2px; }
  .pack__inc { font-size: 0.98rem; color: var(--bone); line-height: 1.4; }
  .pack__inc b { color: var(--gold); font-weight: 600; margin-right: 6px; }

  .pack__meta { display: flex; flex-wrap: wrap; gap: 8px 18px; padding-top: 4px; border-top: 1px solid var(--line); }
  .pack__m { display: inline-flex; align-items: center; gap: 7px; font-size: 0.85rem; color: var(--bone-dim); padding-top: 8px; }
  .pack__mi { display: inline-flex; width: 17px; height: 17px; color: var(--gold); flex: 0 0 auto; }
  .pack__mi :global(svg) { width: 100%; height: 100%; }

  .pack__go { display: inline-flex; align-items: center; gap: 8px; margin-top: 2px; font-family: var(--font-mono); font-size: 0.72rem; letter-spacing: 0.16em; text-transform: uppercase; color: var(--bone-mute); transition: color 0.3s var(--ease); }
  .pack__go i { font-style: normal; transition: transform 0.3s var(--ease); }
  .pack:hover .pack__go { color: var(--gold-bright); }
  .pack:hover .pack__go i { transform: translateX(5px); }

  /* ---------- 02 · steppers ---------- */
  .trow { display: flex; align-items: center; justify-content: space-between; gap: 16px; padding: 18px 0; border-top: 1px solid var(--line); }
  .trow:first-child { border-top: 0; padding-top: 0; }
  .trow__info { display: flex; flex-direction: column; gap: 3px; }
  .trow__label { color: var(--bone); font-weight: 500; font-size: 1.05rem; }
  .trow__sub { color: var(--bone-mute); font-size: 0.85rem; }
  .trow__sub b { color: var(--gold); font-weight: 500; }
  .stepper { display: flex; align-items: center; gap: 0; border: 1px solid var(--line-strong); border-radius: 100px; overflow: hidden; }
  .stepper__b { width: 44px; height: 44px; border: 0; background: transparent; color: var(--bone); font-size: 1.3rem; line-height: 1; cursor: pointer; display: grid; place-items: center; transition: background 0.2s var(--ease), color 0.2s var(--ease); }
  .stepper__b:hover { background: var(--char-3); color: var(--gold-bright); }
  .stepper__b:disabled { opacity: 0.3; cursor: default; background: transparent; }
  .stepper__n { min-width: 40px; text-align: center; font-family: var(--font-display-reg); font-weight: 500; font-size: 1.15rem; }

  /* ---------- 03 · date timeline ---------- */
  .cal { display: flex; gap: 12px; overflow-x: auto; padding: 4px 2px 14px; scrollbar-width: thin; scroll-snap-type: x proximity; }
  .day {
    flex: 0 0 auto; width: 98px; scroll-snap-align: start;
    display: flex; flex-direction: column; align-items: center; gap: 4px;
    padding: 16px 10px 14px; background: var(--char-2); border: 1px solid var(--line); border-radius: 6px;
    color: var(--bone-dim); cursor: pointer; font-family: inherit;
    transition: border-color 0.25s var(--ease), background 0.25s var(--ease), color 0.25s var(--ease), transform 0.25s var(--ease);
  }
  .day:hover:not(:disabled) { border-color: var(--gold); color: var(--bone); transform: translateY(-2px); }
  .day:disabled { opacity: 0.32; cursor: default; }
  .day[aria-pressed='true'] { background: var(--gold); border-color: var(--gold); color: var(--ink); box-shadow: 0 0 30px rgba(198, 161, 91, 0.35); }
  .day__wd { font-family: var(--font-mono); font-size: 0.64rem; letter-spacing: 0.18em; text-transform: uppercase; opacity: 0.8; }
  .day__num { font-family: var(--font-display-reg); font-weight: 500; font-size: 1.9rem; line-height: 1; }
  .day__mo { font-family: var(--font-mono); font-size: 0.62rem; letter-spacing: 0.12em; text-transform: uppercase; opacity: 0.8; }

  /* ---------- 04 · time chips ---------- */
  .sessions { display: flex; flex-wrap: wrap; gap: 12px; }
  .slot { display: inline-flex; align-items: center; gap: 10px; padding: 14px 22px; background: var(--char-2); border: 1px solid var(--line); border-radius: 100px; color: var(--bone-dim); cursor: pointer; font-family: inherit; transition: border-color 0.25s var(--ease), background 0.25s var(--ease), color 0.25s var(--ease); }
  .slot:hover { border-color: var(--gold); color: var(--bone); }
  .slot[aria-pressed='true'] { background: var(--gold); border-color: var(--gold); color: var(--ink); }
  .slot__t { font-family: var(--font-mono); font-size: 1rem; letter-spacing: 0.04em; }
  .slot__seats { font-family: var(--font-mono); font-size: 0.6rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--signal); }
  .slot[aria-pressed='true'] .slot__seats { color: rgba(12, 12, 11, 0.7); }

  /* ---------- Your Visit ---------- */
  .bsum {
    position: sticky; top: calc(var(--nav-h) + 20px);
    background: linear-gradient(170deg, var(--char-2), var(--char));
    border: 1px solid var(--line-strong); border-radius: 6px;
    padding: 26px 24px; box-shadow: 0 24px 60px rgba(0, 0, 0, 0.45);
  }
  .bsum__title { font-family: var(--font-mono); font-size: 0.7rem; letter-spacing: 0.26em; text-transform: uppercase; color: var(--gold); margin: 0 0 18px; }
  .bsum__rows { display: grid; gap: 0; margin-bottom: 18px; }
  .bsum__row { display: flex; justify-content: space-between; gap: 14px; padding: 10px 0; border-bottom: 1px solid var(--line); }
  .bsum__k { font-family: var(--font-mono); font-size: 0.66rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--bone-mute); padding-top: 3px; }
  .bsum__v { font-size: 0.95rem; color: var(--bone); text-align: right; line-height: 1.45; }
  .bsum__total { display: flex; justify-content: space-between; align-items: baseline; padding: 16px 0 20px; }
  .bsum__total span { font-family: var(--font-mono); font-size: 0.72rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--bone-dim); }
  .bsum__total strong { font-family: var(--font-display-xl); font-weight: 400; font-size: 2.3rem; color: var(--bone); line-height: 1; }
  .bsum__cta { width: 100%; justify-content: center; text-align: center; }
  .bsum__secure { text-align: center; font-family: var(--font-mono); font-size: 0.64rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--bone-mute); margin: 14px 0 0; }

  @media (max-width: 979px) {
    .bsum { position: sticky; bottom: 10px; top: auto; z-index: 40; }
  }
</style>

<script>
  const root = document.querySelector<HTMLElement>('[data-booking]');
  if (root) {
    const PACKAGES = JSON.parse(root.querySelector('[data-packages]')!.textContent || '[]');
    const el = (s: string) => root.querySelector(s) as HTMLElement;

    const state: any = { pkg: null, byDate: {}, date: null, session: null, qty: {}, loaded: false };

    const WD = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];
    const MO = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
    const money = (n: number) => '$' + n.toLocaleString();
    const count = () => (state.pkg ? state.pkg.tiers.reduce((s: number, t: any) => s + (state.qty[t.code] || 0), 0) : 0);
    const total = () => (state.pkg ? state.pkg.tiers.reduce((s: number, t: any) => s + t.price * (state.qty[t.code] || 0), 0) : 0);

    /* ---- 01 · package select ---- */
    const packBtns = Array.from(root.querySelectorAll<HTMLButtonElement>('[data-pkg]'));
    function selectPkg(slug: string, scroll = true) {
      const pkg = PACKAGES.find((p: any) => p.slug === slug);
      if (!pkg || state.pkg?.slug === slug) return;
      state.pkg = pkg; state.date = null; state.session = null; state.qty = {}; state.loaded = false;
      pkg.tiers.forEach((t: any) => (state.qty[t.code] = 0));
      packBtns.forEach((b) => b.setAttribute('aria-pressed', String(b.dataset.pkg === slug)));
      el('[data-step-who]').hidden = false;
      el('[data-step-date]').hidden = false;
      el('[data-step-session]').hidden = true;
      renderTickets();
      load(pkg);
      sync();
      if (scroll) document.getElementById('step-who')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
    packBtns.forEach((b) => b.addEventListener('click', () => selectPkg(b.dataset.pkg!)));
    const want = new URLSearchParams(location.search).get('pkg');
    if (want) setTimeout(() => selectPkg(want), 60);

    /* ---- 02 · steppers ---- */
    function renderTickets() {
      const c = el('[data-tickets]'); c.innerHTML = '';
      state.pkg.tiers.forEach((t: any) => {
        const row = document.createElement('div'); row.className = 'trow';
        row.innerHTML =
          `<div class="trow__info"><span class="trow__label">${t.label}</span><span class="trow__sub"><b>${money(t.price)}</b>${t.note ? ' · ' + t.note : ''}</span></div>` +
          `<div class="stepper"><button type="button" class="stepper__b" data-dec aria-label="Fewer ${t.label}">−</button><span class="stepper__n" data-count aria-live="polite">0</span><button type="button" class="stepper__b" data-inc aria-label="More ${t.label}">+</button></div>`;
        const cnt = row.querySelector('[data-count]') as HTMLElement;
        const dec = row.querySelector('[data-dec]') as HTMLButtonElement;
        const upd = () => { cnt.textContent = String(state.qty[t.code]); dec.disabled = state.qty[t.code] === 0; sync(); };
        dec.addEventListener('click', () => { state.qty[t.code] = Math.max(0, state.qty[t.code] - 1); upd(); });
        row.querySelector('[data-inc]')!.addEventListener('click', () => { state.qty[t.code] = Math.min(t.max || 20, state.qty[t.code] + 1); upd(); });
        dec.disabled = true;
        c.appendChild(row);
      });
    }

    /* ---- 03 · date timeline (28 days, unavailable greyed) ---- */
    async function load(pkg: any) {
      const c = el('[data-dates]');
      c.innerHTML = '<p class="hint">Loading availability…</p>';
      let data: any = null;
      try { const r = await fetch(`/api/availability?product=${encodeURIComponent(pkg.productCode)}`); data = await r.json(); } catch { data = null; }
      if (!data || !data.sessions) data = { mock: true, sessions: [] };
      el('[data-mocknote]').hidden = !data.mock;
      state.byDate = {};
      data.sessions.forEach((s: any) => { if (s.seatsAvailable === 0) return; (state.byDate[s.date] = state.byDate[s.date] || []).push(s); });
      state.loaded = true;
      renderCal();
    }
    function renderCal() {
      const c = el('[data-dates]'); c.innerHTML = '';
      const today = new Date();
      for (let i = 0; i < 28; i++) {
        const d = new Date(today); d.setDate(today.getDate() + i);
        const iso = `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`;
        const has = !!state.byDate[iso];
        const b = document.createElement('button');
        b.type = 'button'; b.className = 'day'; b.disabled = !has; b.setAttribute('aria-pressed', 'false');
        b.innerHTML = `<span class="day__wd">${WD[d.getDay()]}</span><span class="day__num">${d.getDate()}</span><span class="day__mo">${MO[d.getMonth()]}</span>`;
        if (has) b.addEventListener('click', () => {
          state.date = iso; state.session = null;
          c.querySelectorAll('.day').forEach((x) => x.setAttribute('aria-pressed', 'false'));
          b.setAttribute('aria-pressed', 'true');
          el('[data-step-session]').hidden = false;
          renderSessions(); sync();
        });
        c.appendChild(b);
      }
    }

    /* ---- 04 · time ---- */
    function renderSessions() {
      const c = el('[data-sessions]'); c.innerHTML = '';
      (state.byDate[state.date] || []).sort((a: any, b: any) => a.time.localeCompare(b.time)).forEach((s: any) => {
        const low = s.seatsAvailable != null && s.seatsAvailable <= 8;
        const b = document.createElement('button');
        b.type = 'button'; b.className = 'slot'; b.setAttribute('aria-pressed', 'false');
        b.innerHTML = `<span class="slot__t">${s.time}</span>${low ? `<span class="slot__seats">${s.seatsAvailable} left</span>` : ''}`;
        b.addEventListener('click', () => {
          state.session = s;
          c.querySelectorAll('.slot').forEach((x) => x.setAttribute('aria-pressed', 'false'));
          b.setAttribute('aria-pressed', 'true');
          sync();
        });
        c.appendChild(b);
      });
    }

    /* ---- Your Visit ---- */
    const cta = el('[data-book]') as HTMLButtonElement;
    function sync() {
      el('[data-sum-pkg]').textContent = state.pkg ? state.pkg.name : '—';
      const parts = state.pkg ? state.pkg.tiers.filter((t: any) => state.qty[t.code] > 0).map((t: any) => `${state.qty[t.code]} × ${t.label}`) : [];
      el('[data-sum-qty]').textContent = parts.length ? parts.join(', ') : '—';
      if (state.date) {
        const d = new Date(state.date + 'T00:00:00');
        el('[data-sum-date]').textContent = `${WD[d.getDay()]} ${d.getDate()} ${MO[d.getMonth()]}`;
      } else el('[data-sum-date]').textContent = '—';
      el('[data-sum-time]').textContent = state.session ? state.session.time : '—';
      el('[data-total]').textContent = money(total());

      const n = count();
      if (!state.pkg || n === 0) { cta.textContent = 'Continue'; cta.disabled = !state.pkg; }
      else if (!state.date || !state.session) { cta.textContent = `Book ${n} Ticket${n > 1 ? 's' : ''} • ${money(total())}`; cta.disabled = false; }
      else { cta.textContent = `Secure Checkout • ${money(total())}`; cta.disabled = false; }
    }
    cta.addEventListener('click', () => {
      if (!state.pkg) return;
      if (count() === 0) { document.getElementById('step-who')?.scrollIntoView({ behavior: 'smooth' }); return; }
      if (!state.date) { document.getElementById('step-date')?.scrollIntoView({ behavior: 'smooth' }); return; }
      if (!state.session) { document.getElementById('step-time')?.scrollIntoView({ behavior: 'smooth' }); return; }
      const params = new URLSearchParams({ date: state.date, time: state.session.time });
      state.pkg.tiers.forEach((t: any) => { if (state.qty[t.code]) params.set(t.code, String(state.qty[t.code])); });
      window.open(`${state.pkg.checkoutUrl}?${params.toString()}`, '_blank', 'noopener');
    });
    sync();
  }
</script>
