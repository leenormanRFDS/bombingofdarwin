---
import { LOCALES } from '../consts';
---
<div class="lang" role="group" aria-label="Choose language">
  {LOCALES.map((l) => (
    <button type="button" class="lang__btn" data-locale={l.code} aria-label={l.name} lang={l.code}>
      {l.label}
    </button>
  ))}
</div>

<style>
  .lang {
    display: inline-flex;
    align-items: center;
    gap: 2px;
    padding: 3px;
    border: 1px solid var(--line);
    border-radius: var(--radius-pill);
    background: rgba(255, 255, 255, 0.02);
  }
  .lang__btn {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    color: var(--cream-mute);
    background: transparent;
    border: none;
    border-radius: var(--radius-pill);
    padding: 5px 10px;
    cursor: pointer;
    transition: color 0.2s var(--ease), background 0.2s var(--ease);
    line-height: 1;
  }
  .lang__btn:hover { color: var(--cream); }
  .lang__btn[aria-current='true'] {
    color: var(--ink);
    background: var(--hud);
  }
</style>

<script>
  // Shell only for now — full translation (EN / 简体中文 / 日本語) is wired
  // in the translation brick. This just reflects the choice visually and
  // sets <html lang> so the browser's built-in translate has the right hint.
  const btns = document.querySelectorAll<HTMLButtonElement>('.lang__btn');
  const saved = localStorage.getItem('bod-locale') || 'en';
  const apply = (code: string) => {
    btns.forEach((b) => b.setAttribute('aria-current', String(b.dataset.locale === code)));
    document.documentElement.lang = code;
  };
  apply(saved);
  btns.forEach((b) =>
    b.addEventListener('click', () => {
      const code = b.dataset.locale || 'en';
      localStorage.setItem('bod-locale', code);
      apply(code);
    })
  );
</script>
