---
// Google Analytics 4. Loaded ONLY in production builds, and skipped on
// localhost at runtime — so `npm run dev` and `npm run preview` never
// pollute your stats. Measurement ID kept in sync with consts.ts.
const enabled = import.meta.env.PROD;
---
{enabled && (
  <script is:inline>
    if (!/^(localhost|127\.0\.0\.1|\[::1\])$/.test(location.hostname)) {
      var s = document.createElement('script');
      s.async = true;
      s.src = 'https://www.googletagmanager.com/gtag/js?id=G-MQ9641V0NY';
      document.head.appendChild(s);
      window.dataLayer = window.dataLayer || [];
      function gtag() { dataLayer.push(arguments); }
      gtag('js', new Date());
      gtag('config', 'G-MQ9641V0NY');
    }
  </script>
)}
